pipeline {
    agent any

    stages {

        stage('Clone Repo') {
            steps {
                git 'https://github.com/rushikeshbhatjire/Rushikeshportfolio.git'
            }
        }

        stage('Deploy to Nginx') {
            steps {
                sh '''
                rm -rf /usr/share/nginx/html/*
                cp -r * /usr/share/nginx/html/
                '''
            }
        }
    }
}
